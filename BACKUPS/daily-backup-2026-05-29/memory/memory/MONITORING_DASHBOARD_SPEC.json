{
  "dashboard_metadata": {
    "version": "1.0",
    "created_date": "2026-05-28",
    "description": "DSC FMS 인프라 모니터링 대시보드 명세서 (15명 분산팀)",
    "last_updated": "2026-05-28",
    "compliance": ["Google SRE", "AWS CloudWatch", "Datadog"]
  },
  "dashboards": [
    {
      "dashboard_id": "ceo-executive-overview",
      "dashboard_name": "CEO 대시보드 — 실시간 상태판",
      "description": "경영진 레벨 고차원적 시스템 건강도 추적",
      "target_audience": ["CEO", "CTO"],
      "refresh_interval_seconds": 60,
      "time_range_presets": ["1h", "7d", "30d"],
      "widgets": [
        {
          "widget_id": "w1",
          "title": "시스템 가용성 (7일 평균)",
          "type": "gauge",
          "metric": "system.uptime_percentage",
          "threshold": {
            "green": [99.5, 100],
            "yellow": [99, 99.5],
            "red": [0, 99]
          },
          "unit": "%",
          "datasource": "cloudwatch"
        },
        {
          "widget_id": "w2",
          "title": "전체 요청 에러율 추이 (30일)",
          "type": "timeseries",
          "metrics": [
            {
              "name": "api.error_rate",
              "stat": "Average",
              "color": "#d9534f"
            },
            {
              "name": "api.error_rate",
              "stat": "p99",
              "color": "#f0ad4e"
            }
          ],
          "unit": "%",
          "threshold_line": 0.1,
          "legend_display": "table"
        },
        {
          "widget_id": "w3",
          "title": "4대 프로젝트 배포 상태",
          "type": "status_panel",
          "projects": [
            {
              "name": "Asset Master",
              "metric": "vercel.deployment.status",
              "last_deployment_time_metric": "vercel.last_deployment_timestamp"
            },
            {
              "name": "Backup App",
              "metric": "vercel.deployment.status",
              "last_deployment_time_metric": "vercel.last_deployment_timestamp"
            },
            {
              "name": "Travel Management",
              "metric": "vercel.deployment.status",
              "last_deployment_time_metric": "vercel.last_deployment_timestamp"
            },
            {
              "name": "Discord Bot",
              "metric": "discord_bot.status",
              "last_deployment_time_metric": "discord_bot.last_update_timestamp"
            }
          ],
          "status_mapping": {
            "1": "✅ 정상",
            "0": "🔴 장애"
          }
        },
        {
          "widget_id": "w4",
          "title": "월간 비용 추적",
          "type": "number",
          "metrics": [
            {
              "name": "aws.estimated_monthly_cost",
              "stat": "Sum"
            }
          ],
          "unit": "USD",
          "target_threshold": 500,
          "warning_threshold": 450
        }
      ]
    },
    {
      "dashboard_id": "devops-detailed-metrics",
      "dashboard_name": "DevOps 대시보드 — 상세 메트릭",
      "description": "인프라 엔지니어용 심화 모니터링 대시보드",
      "target_audience": ["DevOps", "Platform Engineers"],
      "refresh_interval_seconds": 30,
      "time_range_presets": ["15m", "1h", "7d"],
      "widgets": [
        {
          "widget_id": "d1",
          "title": "API 응답시간 분포 (실시간)",
          "type": "heatmap",
          "metrics": [
            {
              "name": "api.latency_milliseconds",
              "statistics": ["p50", "p75", "p90", "p99", "p99.9"],
              "buckets": [0, 50, 100, 200, 500, 1000, 5000]
            }
          ],
          "unit": "ms",
          "color_scheme": "YlOrRd"
        },
        {
          "widget_id": "d2",
          "title": "Supabase DB 연결 풀 상태",
          "type": "multiline_chart",
          "metrics": [
            {
              "name": "supabase.db.active_connections",
              "stat": "Average",
              "color": "#5cb85c",
              "label": "활성 연결"
            },
            {
              "name": "supabase.db.idle_connections",
              "stat": "Average",
              "color": "#5bc0de",
              "label": "유휴 연결"
            },
            {
              "name": "supabase.db.max_connections",
              "stat": "Average",
              "color": "#d9534f",
              "label": "최대 연결수 (한계선)"
            }
          ],
          "unit": "connections"
        },
        {
          "widget_id": "d3",
          "title": "Vercel 배포 성공률 (14일)",
          "type": "bar_chart",
          "metrics": [
            {
              "name": "vercel.deployment.success_rate",
              "stat": "Average",
              "period": "1d"
            }
          ],
          "unit": "%",
          "threshold_line": 95
        },
        {
          "widget_id": "d4",
          "title": "느린 쿼리 감시 (>500ms)",
          "type": "table",
          "query": {
            "source": "cloudwatch_logs",
            "log_group": "/aws/supabase/postgres",
            "filter_pattern": "[time, duration > 500, query]",
            "fields": ["timestamp", "query", "duration_ms", "caller_ip"],
            "sort_by": "duration_ms",
            "order": "descending",
            "limit": 50
          }
        },
        {
          "widget_id": "d5",
          "title": "Supabase 저장소 사용률",
          "type": "gauge",
          "metrics": [
            {
              "name": "supabase.storage.used_gb",
              "stat": "Average"
            },
            {
              "name": "supabase.storage.quota_gb",
              "stat": "Average"
            }
          ],
          "threshold": {
            "green": [0, 70],
            "yellow": [70, 90],
            "red": [90, 100]
          },
          "unit": "%"
        }
      ]
    },
    {
      "dashboard_id": "team-collaboration-board",
      "dashboard_name": "팀 협업 보드 — 프로젝트 진행도",
      "description": "15명 팀의 프로젝트 상태 실시간 추적",
      "target_audience": ["Team Members", "Project Managers"],
      "refresh_interval_seconds": 120,
      "time_range_presets": ["1h", "1d", "7d"],
      "widgets": [
        {
          "widget_id": "t1",
          "title": "Asset Master — 배포 빈도",
          "type": "bar_chart",
          "metrics": [
            {
              "name": "asset_master.deployments_per_day",
              "stat": "Sum",
              "period": "1d"
            }
          ],
          "unit": "배포/일"
        },
        {
          "widget_id": "t2",
          "title": "Backup App — 성공/실패율",
          "type": "pie_chart",
          "metrics": [
            {
              "name": "backup_app.backup_success_count",
              "stat": "Sum"
            },
            {
              "name": "backup_app.backup_failure_count",
              "stat": "Sum"
            }
          ]
        },
        {
          "widget_id": "t3",
          "title": "Travel Management — 요청 처리량",
          "type": "timeseries",
          "metrics": [
            {
              "name": "travel.requests_per_minute",
              "stat": "Sum",
              "color": "#0275d8"
            }
          ],
          "unit": "요청/분"
        },
        {
          "widget_id": "t4",
          "title": "Discord Bot — 메시지 처리율",
          "type": "gauge",
          "metrics": [
            {
              "name": "discord_bot.message_success_rate",
              "stat": "Average"
            }
          ],
          "unit": "%",
          "threshold": {
            "green": [99, 100],
            "yellow": [95, 99],
            "red": [0, 95]
          }
        }
      ]
    }
  ],
  "alert_payload_schemas": {
    "cloudwatch_alert": {
      "type": "object",
      "properties": {
        "AlarmName": {
          "type": "string",
          "description": "경보 이름 (예: 'api-latency-p99-high')"
        },
        "AlarmDescription": {
          "type": "string",
          "description": "경보 설명"
        },
        "StateChangeTime": {
          "type": "string",
          "format": "date-time",
          "description": "상태 변경 시간 (ISO 8601)"
        },
        "NewStateValue": {
          "type": "string",
          "enum": ["ALARM", "OK", "INSUFFICIENT_DATA"],
          "description": "새로운 상태"
        },
        "Trigger": {
          "type": "object",
          "properties": {
            "MetricName": {
              "type": "string"
            },
            "Namespace": {
              "type": "string"
            },
            "Dimensions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "value": {"type": "string"}
                }
              }
            },
            "Statistic": {
              "type": "string",
              "enum": ["Average", "Sum", "Maximum", "Minimum", "SampleCount"]
            },
            "Period": {
              "type": "integer",
              "description": "통계 기간 (초)"
            },
            "EvaluationPeriods": {
              "type": "integer"
            },
            "Threshold": {
              "type": "number"
            },
            "ComparisonOperator": {
              "type": "string",
              "enum": ["GreaterThanOrEqualToThreshold", "GreaterThanThreshold", "LessThanThreshold", "LessThanOrEqualToThreshold"]
            }
          }
        }
      },
      "required": ["AlarmName", "StateChangeTime", "NewStateValue", "Trigger"]
    },
    "incident_alert": {
      "type": "object",
      "properties": {
        "incident_id": {
          "type": "string",
          "format": "uuid",
          "description": "인시던트 고유 ID"
        },
        "severity": {
          "type": "string",
          "enum": ["Critical", "High", "Medium", "Low"],
          "description": "심각도 레벨"
        },
        "affected_service": {
          "type": "string",
          "description": "영향받은 서비스 (예: 'api', 'database', 'deployment')"
        },
        "detected_at": {
          "type": "string",
          "format": "date-time"
        },
        "metric_snapshot": {
          "type": "object",
          "properties": {
            "current_value": {"type": "number"},
            "threshold": {"type": "number"},
            "unit": {"type": "string"},
            "comparison": {"type": "string"}
          }
        },
        "escalation_tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "에스컬레이션 단계"
        },
        "assigned_to": {
          "type": "string",
          "description": "온콜 담당자"
        }
      },
      "required": ["incident_id", "severity", "affected_service", "detected_at"]
    }
  },
  "metric_definitions": {
    "golden_signals": [
      {
        "name": "Latency",
        "metrics": [
          "api.latency_milliseconds",
          "supabase.db.query.duration_ms"
        ],
        "slo_target": "<200ms (p99)",
        "measurement_interval": "1m"
      },
      {
        "name": "Traffic",
        "metrics": [
          "api.requests_per_minute",
          "vercel.edge.requests_per_minute"
        ],
        "unit": "requests/min",
        "measurement_interval": "1m"
      },
      {
        "name": "Errors",
        "metrics": [
          "api.error_rate",
          "supabase.db.connection_errors",
          "vercel.deployment.failures"
        ],
        "slo_target": "<0.1%",
        "unit": "%",
        "measurement_interval": "5m"
      },
      {
        "name": "Saturation",
        "metrics": [
          "supabase.db.active_connections_percent",
          "vercel.cold_start_count",
          "aws.storage.usage_percent"
        ],
        "slo_target": "<70%",
        "unit": "%",
        "measurement_interval": "5m"
      }
    ],
    "custom_business_metrics": [
      {
        "name": "asset_registration_rate",
        "description": "일일 자산 등록 수",
        "unit": "assets/day",
        "collection_method": "CloudWatch Custom Metric",
        "application_layer": "Asset Master API"
      },
      {
        "name": "backup_completion_rate",
        "description": "백업 작업 성공률",
        "unit": "%",
        "collection_method": "Application Logging",
        "threshold_alert": "< 98%"
      },
      {
        "name": "travel_request_processing_time",
        "description": "여행 요청 평균 처리시간",
        "unit": "seconds",
        "collection_method": "API Response Time Tracking",
        "slo_target": "< 30초"
      },
      {
        "name": "discord_message_latency",
        "description": "Discord 메시지 전달 지연시간",
        "unit": "milliseconds",
        "collection_method": "Discord Bot Telemetry",
        "threshold_alert": "> 5000ms"
      }
    ]
  },
  "integration_endpoints": [
    {
      "endpoint_id": "cloudwatch_api",
      "service": "AWS CloudWatch",
      "base_url": "https://monitoring.{region}.amazonaws.com",
      "authentication": "AWS Signature v4",
      "endpoints": [
        {
          "method": "GET",
          "path": "/metrics",
          "description": "메트릭 조회"
        },
        {
          "method": "POST",
          "path": "/put-metric-data",
          "description": "커스텀 메트릭 전송"
        },
        {
          "method": "GET",
          "path": "/describe-alarms",
          "description": "경보 목록 조회"
        }
      ]
    },
    {
      "endpoint_id": "datadog_api",
      "service": "Datadog (Optional)",
      "base_url": "https://api.datadoghq.com/api/v1",
      "authentication": "API Key + App Key",
      "endpoints": [
        {
          "method": "GET",
          "path": "/series",
          "description": "시계열 데이터 조회"
        },
        {
          "method": "POST",
          "path": "/events",
          "description": "인시던트 이벤트 기록"
        },
        {
          "method": "GET",
          "path": "/monitor",
          "description": "모니터 설정 조회"
        }
      ]
    },
    {
      "endpoint_id": "supabase_analytics",
      "service": "Supabase Analytics API",
      "base_url": "https://api.supabase.com/v1/projects/{project_id}/analytics",
      "authentication": "Bearer {access_token}",
      "endpoints": [
        {
          "method": "GET",
          "path": "/db/stats",
          "description": "DB 통계"
        },
        {
          "method": "GET",
          "path": "/storage/stats",
          "description": "저장소 사용량"
        }
      ]
    }
  ],
  "dashboard_colors": {
    "status_green": "#5cb85c",
    "status_yellow": "#f0ad4e",
    "status_red": "#d9534f",
    "error_line": "#d9534f",
    "warning_line": "#f0ad4e",
    "success_line": "#5cb85c",
    "neutral_line": "#0275d8"
  },
  "refresh_intervals": {
    "real_time": 10,
    "fast": 30,
    "standard": 60,
    "slow": 300
  }
}
